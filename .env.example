# ── React UI ─────────────────────────────────────────────────────────────────
# WebSocket URL — must match your server's public address
VITE_WS_URL=ws://yourserver.com/ws/logs

# UI display limits
VITE_MAX_LOGS_PER_TOPIC=500
VITE_MAX_MESSAGE_LENGTH=50000

# ── SSO (filled automatically from Keycloak settings below) ──────────────────
# The Keycloak realm URL — oidc-client-ts uses this to auto-discover all OIDC endpoints
VITE_SSO_LOGIN_URL=http://yourserver.com/auth/realms/logstream

# Logout redirect (post-logout landing page)
VITE_SSO_LOGOUT_URL=http://yourserver.com/auth/realms/logstream/protocol/openid-connect/logout

# Token endpoint (for reference — auto-discovered from authority)
VITE_SSO_TOKEN_URL=http://yourserver.com/auth/realms/logstream/protocol/openid-connect/token

# Must match the clientId in keycloak/realm-export.json
VITE_SSO_CLIENT_ID=logstream-ui

# ── Keycloak ──────────────────────────────────────────────────────────────────
# Initial admin credentials (change after first login)
KC_ADMIN=admin
KC_ADMIN_PASSWORD=changeme

# Full public URL of your server — Keycloak uses this to build redirect URLs
KC_HOSTNAME_URL=http://yourserver.com

# JWKS URI — used by Spring Boot to validate JWTs (copy to logstream .env)
# SSO_JWKS_URI=http://yourserver.com/auth/realms/logstream/protocol/openid-connect/certs
